<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Action Window -->
    <record id="action_account_tax_tag" model="ir.actions.act_window">
        <field name="name">Tax Tags</field>
        <field name="res_model">account.tax.tag</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_account_tax_tag_tree"/>
        <field name="search_view_id" ref="view_account_tax_tag_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new tax tag
            </p>
            <p>
                Tax tags allow you to control which taxes will be triggered
                for products in different contexts (sales/purchases) based
                on customizable conditions.
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem
        id="menu_account_tax_tag"
        name="Tax Tags"
        parent="account.account_account_menu"
        action="action_account_tax_tag"
        sequence="3"
        groups="account.group_account_manager"/>
</odoo>
