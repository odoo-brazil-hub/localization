<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View (List) for account.tax.tag -->
    <record id="view_account_tax_tag_tree" model="ir.ui.view">
        <field name="name">account.tax.tag.list</field>
        <field name="model">account.tax.tag</field>
        <field name="arch" type="xml">
            <list string="Tax Tags">
                <field name="name"/>
                <field name="summary" optional="show"/>
                <field name="using_on"/>
                <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}"/>
                <field name="base_country_id" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Form View for account.tax.tag -->
    <record id="view_account_tax_tag_form" model="ir.ui.view">
        <field name="name">account.tax.tag.form</field>
        <field name="model">account.tax.tag</field>
        <field name="arch" type="xml">
            <form string="Tax Tag">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Name"/>
                        </h1>
                    </div>
                    <group>
                        <field name="summary"/>
                    </group>
                    <group>
                        <group name="general_settings">
                            <field name="using_on"/>
                            <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}"/>
                            <field name="base_country_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Tag Lines" name="tag_lines">
                            <field name="line_ids">
                                <list editable="bottom" create="1" delete="1">
                                    <field name="country_id" widget="many2many_tags" options="{'no_create': True}" optional="show"/>
                                    <field name="country_state_ids" widget="many2many_tags" options="{'no_create': True}" optional="show"/>
                                    <field name="country_city_ids" widget="many2many_tags" options="{'no_create': True}" optional="hide"/>
                                    <field name="country_group_id" options="{'no_create': True}" optional="hide"/>
                                    <field name="partner_id" optional="hide"/>
                                    <field name="tax_ids" widget="many2many_tags" options="{'no_create': True}"/>
                                    <field name="company_id" column_invisible="True"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View for account.tax.tag -->
    <record id="view_account_tax_tag_search" model="ir.ui.view">
        <field name="name">account.tax.tag.search</field>
        <field name="model">account.tax.tag</field>
        <field name="arch" type="xml">
            <search string="Search Tax Tags">
                <field name="name"/>
                <field name="summary"/>
                <field name="using_on"/>
                <field name="company_id"/>
                <filter string="Sales" name="filter_sale" domain="[('using_on', '=', 'sale')]"/>
                <filter string="Purchases" name="filter_purchase" domain="[('using_on', '=', 'purchase')]"/>
                <separator/>
                <filter string="Country" name="group_by_country" context="{'group_by': 'base_country_id'}"/>
            </search>
        </field>
    </record>

</odoo>
