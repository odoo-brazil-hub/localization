<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_product_template_form_inherit_tax_mapper" model="ir.ui.view">
        <field name="name">product.template.form.inherit.tax.mapper</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <field name="categ_id" position="before">
                <field name="sale_tax_tag_ids"
                       widget="many2many_tags"
                       options="{'no_create': True, 'color_field': 'color'}"
                       invisible="not sale_ok"
                       placeholder="Select sale tax mappers..."/>
                <field name="purchase_tax_tag_ids"
                       widget="many2many_tags"
                       options="{'no_create': True, 'color_field': 'color'}"
                       invisible="not purchase_ok"
                       placeholder="Select purchase tax mappers..."/>
            </field>
        </field>
    </record>

</odoo>
