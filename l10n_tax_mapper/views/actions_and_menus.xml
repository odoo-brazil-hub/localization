<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Action Window -->
    <record id="action_tax_mapper" model="ir.actions.act_window">
        <field name="name">Tax Mappers</field>
        <field name="res_model">tax.mapper</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_tax_mapper_tree"/>
        <field name="search_view_id" ref="view_tax_mapper_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new tax mapper
            </p>
            <p>
                Tax mappers allow you to control which taxes will be triggered
                for products in different contexts (sales/purchases) based
                on customizable conditions.
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem
        id="menu_tax_mapper"
        name="Tax Mappers"
        parent="account.account_account_menu"
        action="action_tax_mapper"
        sequence="3"
        groups="account.group_account_manager"/>
</odoo>
